# ============================================
# Site Acsa Carlis - Variáveis de ambiente
# ============================================
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA comite o .env no git.

# --- Google Ads / Tag Manager ---
# Obtenha no Google Ads → Ferramentas → Conversões
# Formato: AW-1234567890
GADS_ID=AW-XXXXXXXXXX

# Label da conversão específica (ex: clique no WhatsApp)
# Formato: aBcDeFgHiJkLmNoPq
GADS_LABEL=XXXXXXXXXXXXXX

# Habilita/desabilita o snippet do Google Ads ("true" para ativar)
GADS_ENABLED=false

# --- Google Tag Manager (opcional, se preferir GTM em vez de gtag direto) ---
# Formato: GTM-XXXXXXX
GTM_ID=

# --- Site ---
# Domínio canônico usado em meta tags e schema.org
SITE_URL=https://www.acsacarlis.adv.br

# --- Container ---
CONTAINER_NAME=acsacarlis-site
IMAGE_TAG=latest

# --- Porta do host (descomente em docker-compose.yml para expor diretamente) ---
HOST_PORT=8080
